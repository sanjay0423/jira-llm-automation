# Copy to .env and fill in values.
# Used by Jira Automation "Send web request" - must match the token in the rule.
JIRA_TRIAGE_TOKEN=your-shared-secret-token

# For script: python triage_issue.py JLA-1 (fetch issue + add comment via REST API)
JIRA_BASE_URL=https://sanjayrane.atlassian.net
JIRA_EMAIL=your-atlassian-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# OpenAI (or compatible API). For Azure OpenAI, set OPENAI_API_BASE and use engine/deployment name as model.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# RAG sources (newline or comma separated URLs). If empty, the app falls back to
# a small Apache Airflow starter set.
# Example:
# RAG_SOURCE_URLS=https://airflow.apache.org/docs/apache-airflow/stable/,https://raw.githubusercontent.com/apache/airflow/main/README.md
RAG_SOURCE_URLS=
RAG_TOP_K=4
RAG_MAX_SOURCE_CHARS=24000
RAG_MAX_SNIPPET_CHARS=600
RAG_TIMEOUT_SECONDS=10.0

# Optional: for Azure OpenAI or other compatible endpoints
# OPENAI_API_BASE=https://your-resource.openai.azure.com/openai/deployments/your-deployment
